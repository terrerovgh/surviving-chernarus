      "      \"min\": 0",
      "    }",
      "  },",
      "  \"interval\": \"${11:30s}\",",
      "  \"description\": \"${12:Panel description for Chernarus monitoring}\"",
      "}",
      "$0"
    ],
    "description": "Grafana dashboard panel configuration for Chernarus monitoring"
  }
}
