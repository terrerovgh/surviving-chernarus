{
  "name": "surviving-chernarus",
  "version": "1.0.0",
  "description": "Portal digital del Operador Terrerov - Beacon de Chernarus",
  "main": "src/index.html",
  "scripts": {
    "dev": "cd src && python3 -m http.server 3000",
    "build": "npm run build:css && npm run build:html",
    "build:css": "cleancss -o _site/css/style.css src/css/style.css",
    "build:html": "html-minifier-terser --collapse-whitespace --remove-comments --remove-optional-tags --remove-redundant-attributes --remove-script-type-attributes --remove-tag-whitespace --use-short-doctype --minify-css true --minify-js true -o _site/index.html src/index.html",
    "serve": "cd _site && python3 -m http.server 8080",
    "clean": "rm -rf _site"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/terrerovgh/surviving-chernarus.git"
  },
  "keywords": [
    "beacon",
    "chernarus",
    "survival",
    "personal-website",
    "github-pages",
    "svg-animation",
    "responsive-design"
  ],
  "author": "Operador Terrerov <contact@terrerov.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/terrerovgh/surviving-chernarus/issues"
  },
  "homepage": "https://www.terrerov.com",
  "devDependencies": {
    "html-minifier-terser": "^7.2.0",
    "clean-css-cli": "^5.6.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}